# ─── LLM Provider ────────────────────────────────────────────────
AGENT_ENGINE_PROVIDER=openai_compat
AGENT_ENGINE_MODEL=gpt-4o-mini
AGENT_ENGINE_API_KEY=sk-YOUR-KEY-HERE
AGENT_ENGINE_BASE_URL=https://api.openai.com/v1

# ─── Memory System ───────────────────────────────────────────────
# Auto memory (LLM writes .md notes after each conversation turn)
UBUILDING_ENABLE_AUTO_MEMORY=1
UBUILDING_REMOTE_MEMORY_DIR=./data/memory
UBUILDING_ENABLE_EXTRACT_MEMORIES=1

# Team memory (shared across team, requires server — leave off for solo)
# UBUILDING_ENABLE_TEAM_MEMORY=1

# Session memory (per-session notes, injected into compact)
UBUILDING_ENABLE_SESSION_MEMORY=1

# Auto-dream (background consolidation of memory files)
UBUILDING_ENABLE_AUTO_DREAM=1
# Dev overrides: lower thresholds for quick testing
UBUILDING_AUTO_DREAM_MIN_HOURS=0
UBUILDING_AUTO_DREAM_MIN_SESSIONS=1

# Skip creating MEMORY.md index file
# UBUILDING_SKIP_MEMORY_INDEX=1

# ─── Server ──────────────────────────────────────────────────────
APP_PORT=8080
DB_PATH=./data/app.db
