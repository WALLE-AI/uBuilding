# ============================================================================
# uBuilding LLM Configuration
# Copy this file to .env and fill in your actual values.
# ============================================================================

# --- vLLM / Local LLM Server ---
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=your-vllm-api-key

# --- Agent Engine (primary LLM for the agent loop) ---
# Provider options: anthropic, openai, openai_compat, ollama, vllm
AGENT_ENGINE_PROVIDER=openai_compat
AGENT_ENGINE_MODEL=gpt-4o-mini
AGENT_ENGINE_API_KEY=sk-your-api-key-here
AGENT_ENGINE_BASE_URL=https://api.openai.com/v1

# --- Coordinator Mode ---
# Set to "true" to enable multi-agent coordinator
CLAUDE_CODE_COORDINATOR_MODE=false

# ============================================================================
# backend/app — Web Server
# ============================================================================

# HTTP listen port
APP_PORT=8080

# SQLite database file path (relative to backend/app/)
DB_PATH=./data/app.db

# System prompt for the agent (override default)
AGENT_SYSTEM_PROMPT=You are a helpful assistant. Be concise and accurate.

# --- Memory ---
# Enable auto-memory: LLM will self-maintain MEMORY.md under
#   %AppData%\ubuilding\projects\<project-key>\memory\  (Windows)
#   ~/.config/ubuilding/projects/<project-key>/memory/  (Linux/macOS)
# UBUILDING_ENABLE_AUTO_MEMORY=1

# Enable team-memory (shared team notes + secret scanning on writes).
# Implies auto-memory.
# UBUILDING_ENABLE_TEAM_MEMORY=1

# Override the memory storage base directory (all projects).
# UBUILDING_REMOTE_MEMORY_DIR=D:\my-memory

# Override this project's memory directory directly.
# UBUILDING_COWORK_MEMORY_PATH_OVERRIDE=D:\my-project-memory

# Enable memory extraction: auto-extract memories from conversation after
# each turn using a background LLM call. Requires auto-memory.
# UBUILDING_ENABLE_EXTRACT_MEMORIES=1

# Daily-log mode: LLM appends timestamped entries to logs/YYYY/MM/YYYY-MM-DD.md
# instead of managing MEMORY.md directly. A nightly process distills logs.
# UBUILDING_ENABLE_DAILY_LOG=1

# ============================================================================
# frontend — Next.js
# ============================================================================

# Backend URL for API proxy (used server-side in next.config.ts rewrites)
# Leave empty to default to http://localhost:8080
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
